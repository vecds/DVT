 9. Additional analysis (e.g., redundant rules)
# Remove redundant rules
redundant_rules <- is.redundant(rules)
rules_pruned <- rules[!redundant_rules]
inspect(rules_pruned[1:10])
# Example: Finding rules with a specific item in the RHS (righthand side)
rhs_milk <- subset(rules, rhs %in% "whole milk")
inspect(rhs_milk)
